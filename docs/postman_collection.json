{
	"info": {
		"name": "Event-Driven Notification API",
		"description": "Complete REST API collection for the Event-Driven Notification System. Supports SMS, Email, and Push channels with priority queues, idempotency, batch processing, templates, scheduling, and real-time status tracking.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "notification_id",
			"value": ""
		},
		{
			"key": "batch_id",
			"value": ""
		},
		{
			"key": "template_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Notifications",
			"item": [
				{
					"name": "Create Notification (SMS)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"recipient\": \"+905551234567\",\n\t\"channel\": \"sms\",\n\t\"content\": \"Your verification code is 123456\",\n\t\"priority\": \"high\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"]
						},
						"description": "Create a single SMS notification with high priority."
					},
					"response": []
				},
				{
					"name": "Create Notification (Email)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"recipient\": \"user@example.com\",\n\t\"channel\": \"email\",\n\t\"content\": \"Welcome to our platform! Your account has been created.\",\n\t\"priority\": \"normal\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"]
						},
						"description": "Create an email notification with normal priority."
					},
					"response": []
				},
				{
					"name": "Create Notification (Push)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"recipient\": \"device-token-abc123\",\n\t\"channel\": \"push\",\n\t\"content\": \"You have a new message!\",\n\t\"priority\": \"low\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"]
						},
						"description": "Create a push notification with low priority."
					},
					"response": []
				},
				{
					"name": "Create Notification (with Idempotency Key)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Idempotency-Key",
								"value": "unique-key-12345"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"recipient\": \"+905551234567\",\n\t\"channel\": \"sms\",\n\t\"content\": \"Idempotent notification — safe to retry\",\n\t\"priority\": \"high\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"]
						},
						"description": "Create a notification with an idempotency key. Sending the same key again returns the original notification (200) instead of creating a duplicate (201)."
					},
					"response": []
				},
				{
					"name": "Create Notification (Scheduled — Future)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"recipient\": \"+905551234567\",\n\t\"channel\": \"sms\",\n\t\"content\": \"This is a scheduled reminder\",\n\t\"priority\": \"normal\",\n\t\"scheduled_at\": \"2028-01-01T10:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"]
						},
						"description": "Create a notification scheduled for a future date. It stays in 'pending' status until the scheduled time arrives."
					},
					"response": []
				},
				{
					"name": "Create Notification (Scheduled — Past, Immediate)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"recipient\": \"+905551234567\",\n\t\"channel\": \"sms\",\n\t\"content\": \"Past-dated schedule sends immediately\",\n\t\"priority\": \"normal\",\n\t\"scheduled_at\": \"2024-01-01T00:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"]
						},
						"description": "Create a notification with a past scheduled_at date. It is dispatched immediately since the scheduled time has already passed."
					},
					"response": []
				},
				{
					"name": "Create Notification (Template-Based)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"recipient\": \"+905551234567\",\n\t\"channel\": \"sms\",\n\t\"priority\": \"high\",\n\t\"template_id\": \"{{template_id}}\",\n\t\"template_variables\": {\n\t\t\"name\": \"John\",\n\t\t\"code\": \"123456\"\n\t}\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"]
						},
						"description": "Create a notification using a template. Content is rendered from the template body with the provided variables. Requires a valid template_id — create a template first."
					},
					"response": []
				},
				{
					"name": "Get Notification by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/notifications/{{notification_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications", "{{notification_id}}"]
						},
						"description": "Get a single notification by ID. Returns full details including status, attempts, timestamps."
					},
					"response": []
				},
				{
					"name": "List Notifications (with Filters)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/notifications?status=delivered&channel=sms&priority=high&date_from=2026-01-01&date_to=2026-12-31&per_page=10",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications"],
							"query": [
								{
									"key": "status",
									"value": "delivered",
									"description": "Filter by status: pending, queued, processing, delivered, failed, retrying, permanently_failed, cancelled"
								},
								{
									"key": "channel",
									"value": "sms",
									"description": "Filter by channel: sms, email, push"
								},
								{
									"key": "priority",
									"value": "high",
									"description": "Filter by priority: high, normal, low"
								},
								{
									"key": "date_from",
									"value": "2026-01-01",
									"description": "Filter notifications created after this date (Y-m-d)"
								},
								{
									"key": "date_to",
									"value": "2026-12-31",
									"description": "Filter notifications created before this date (Y-m-d)"
								},
								{
									"key": "per_page",
									"value": "10",
									"description": "Number of results per page (default: 15)"
								},
								{
									"key": "cursor",
									"value": "",
									"description": "Cursor for pagination (from meta.next_cursor in previous response)",
									"disabled": true
								}
							]
						},
						"description": "List notifications with optional filters and cursor-based pagination. All query parameters are optional."
					},
					"response": []
				},
				{
					"name": "Cancel Notification",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/notifications/{{notification_id}}/cancel",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications", "{{notification_id}}", "cancel"]
						},
						"description": "Cancel a notification. Only works for cancellable statuses: pending, queued, retrying. Returns 409 if the notification is in a non-cancellable status."
					},
					"response": []
				}
			]
		},
		{
			"name": "Batch",
			"item": [
				{
					"name": "Create Batch Notifications",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"notifications\": [\n\t\t{\n\t\t\t\"recipient\": \"+905551234567\",\n\t\t\t\"channel\": \"sms\",\n\t\t\t\"content\": \"Batch SMS message\",\n\t\t\t\"priority\": \"high\"\n\t\t},\n\t\t{\n\t\t\t\"recipient\": \"user@example.com\",\n\t\t\t\"channel\": \"email\",\n\t\t\t\"content\": \"Batch email content\",\n\t\t\t\"priority\": \"normal\"\n\t\t},\n\t\t{\n\t\t\t\"recipient\": \"device-token-xyz\",\n\t\t\t\"channel\": \"push\",\n\t\t\t\"content\": \"Batch push notification\",\n\t\t\t\"priority\": \"low\"\n\t\t}\n\t]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/notifications/batch",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications", "batch"]
						},
						"description": "Create a batch of up to 1000 notifications. Returns batch_id and count. Each notification is processed independently through the priority queue."
					},
					"response": []
				},
				{
					"name": "Get Batch Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/notifications/batch/{{batch_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications", "batch", "{{batch_id}}"]
						},
						"description": "Get batch status by batch_id. Returns total count and per-status breakdown (e.g., delivered: 2, failed: 1)."
					},
					"response": []
				}
			]
		},
		{
			"name": "Templates",
			"item": [
				{
					"name": "List Templates",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/templates",
							"host": ["{{base_url}}"],
							"path": ["api", "templates"]
						},
						"description": "List all notification templates."
					},
					"response": []
				},
				{
					"name": "Create Template",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"Welcome SMS\",\n\t\"body\": \"Hello {name}, your verification code is {code}.\",\n\t\"channel\": \"sms\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/templates",
							"host": ["{{base_url}}"],
							"path": ["api", "templates"]
						},
						"description": "Create a new notification template. Use {variable_name} placeholders in the body for dynamic content."
					},
					"response": []
				},
				{
					"name": "Get Template by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/templates/{{template_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "templates", "{{template_id}}"]
						},
						"description": "Retrieve a single template by its UUID."
					},
					"response": []
				},
				{
					"name": "Update Template",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"Updated Welcome SMS\",\n\t\"body\": \"Hi {name}, welcome aboard! Your code: {code}\",\n\t\"channel\": \"sms\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/templates/{{template_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "templates", "{{template_id}}"]
						},
						"description": "Update an existing template by its UUID."
					},
					"response": []
				},
				{
					"name": "Delete Template",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/templates/{{template_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "templates", "{{template_id}}"]
						},
						"description": "Delete a template by UUID. Returns 409 Conflict if the template is referenced by existing notifications."
					},
					"response": []
				}
			]
		},
		{
			"name": "Observability",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/health",
							"host": ["{{base_url}}"],
							"path": ["api", "health"]
						},
						"description": "Check the health of all services (database, Redis, Horizon). Returns 200 for healthy, 503 for degraded."
					},
					"response": []
				},
				{
					"name": "Metrics",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/metrics",
							"host": ["{{base_url}}"],
							"path": ["api", "metrics"]
						},
						"description": "Get system metrics: queue depths per priority, delivery success/failure rates per channel, average latency per channel, and notification totals by status."
					},
					"response": []
				},
				{
					"name": "Notification Trace",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/notifications/{{notification_id}}/trace",
							"host": ["{{base_url}}"],
							"path": ["api", "notifications", "{{notification_id}}", "trace"]
						},
						"description": "Get the full audit trail / lifecycle trace of a notification. Shows all status transitions with timestamps, correlation IDs, and event details."
					},
					"response": []
				}
			]
		}
	]
}
