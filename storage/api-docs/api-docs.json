{
    "openapi": "3.0.0",
    "info": {
        "title": "Event-Driven Notification API",
        "description": "A scalable notification system that processes and delivers messages through SMS, Email, and Push channels.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080",
            "description": "Local"
        }
    ],
    "paths": {
        "/api/notifications/batch": {
            "post": {
                "tags": [
                    "Batch"
                ],
                "summary": "Create a batch of notifications",
                "description": "Create up to 1000 notifications in a single request.",
                "operationId": "3ae71ed8bdc282b250f25e4cf7f21382",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "notifications"
                                ],
                                "properties": {
                                    "notifications": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "recipient",
                                                "channel",
                                                "content"
                                            ],
                                            "properties": {
                                                "recipient": {
                                                    "type": "string",
                                                    "example": "+905551234567"
                                                },
                                                "channel": {
                                                    "type": "string",
                                                    "enum": [
                                                        "sms",
                                                        "email",
                                                        "push"
                                                    ]
                                                },
                                                "content": {
                                                    "type": "string",
                                                    "example": "Hello!"
                                                },
                                                "priority": {
                                                    "type": "string",
                                                    "enum": [
                                                        "high",
                                                        "normal",
                                                        "low"
                                                    ],
                                                    "nullable": true
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "maxItems": 1000
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Batch created"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/notifications/batch/{batchId}": {
            "get": {
                "tags": [
                    "Batch"
                ],
                "summary": "Get batch status",
                "description": "Returns total count and per-status breakdown for a batch.",
                "operationId": "4904ed3fa2cb5f30a075d7a13b048480",
                "parameters": [
                    {
                        "name": "batchId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Batch status"
                    },
                    "404": {
                        "description": "Batch not found"
                    }
                }
            }
        },
        "/api/health": {
            "get": {
                "tags": [
                    "Observability"
                ],
                "summary": "Health check",
                "description": "Returns service health status for database, Redis, and Horizon.",
                "operationId": "24b74a809d1f5913ec7794d867bc24f4",
                "responses": {
                    "200": {
                        "description": "All services healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "healthy"
                                        },
                                        "services": {
                                            "properties": {
                                                "database": {
                                                    "properties": {
                                                        "status": {
                                                            "type": "string",
                                                            "example": "up"
                                                        },
                                                        "latency_ms": {
                                                            "type": "number",
                                                            "format": "float",
                                                            "example": 1.23
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "redis": {
                                                    "properties": {
                                                        "status": {
                                                            "type": "string",
                                                            "example": "up"
                                                        },
                                                        "latency_ms": {
                                                            "type": "number",
                                                            "format": "float",
                                                            "example": 0.45
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "horizon": {
                                                    "properties": {
                                                        "status": {
                                                            "type": "string",
                                                            "example": "running"
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "One or more services degraded"
                    }
                }
            }
        },
        "/api/metrics": {
            "get": {
                "tags": [
                    "Observability"
                ],
                "summary": "System metrics",
                "description": "Returns queue depths, delivery counts, latency, and notification totals.",
                "operationId": "c0f1186ba74b30d4ac71735318f48807",
                "responses": {
                    "200": {
                        "description": "System metrics",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "queue_depths": {
                                            "properties": {
                                                "high": {
                                                    "type": "integer",
                                                    "example": 0
                                                },
                                                "normal": {
                                                    "type": "integer",
                                                    "example": 5
                                                },
                                                "low": {
                                                    "type": "integer",
                                                    "example": 2
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "deliveries": {
                                            "properties": {
                                                "sms": {
                                                    "properties": {
                                                        "success": {
                                                            "type": "integer",
                                                            "example": 100
                                                        },
                                                        "failure": {
                                                            "type": "integer",
                                                            "example": 3
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "email": {
                                                    "properties": {
                                                        "success": {
                                                            "type": "integer",
                                                            "example": 50
                                                        },
                                                        "failure": {
                                                            "type": "integer",
                                                            "example": 1
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "push": {
                                                    "properties": {
                                                        "success": {
                                                            "type": "integer",
                                                            "example": 75
                                                        },
                                                        "failure": {
                                                            "type": "integer",
                                                            "example": 2
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "latency": {
                                            "properties": {
                                                "sms": {
                                                    "properties": {
                                                        "avg_ms": {
                                                            "type": "number",
                                                            "format": "float",
                                                            "example": 120.5
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "email": {
                                                    "properties": {
                                                        "avg_ms": {
                                                            "type": "number",
                                                            "format": "float",
                                                            "example": 95.3
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "push": {
                                                    "properties": {
                                                        "avg_ms": {
                                                            "type": "number",
                                                            "format": "float",
                                                            "example": 80.1
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "totals": {
                                            "properties": {
                                                "pending": {
                                                    "type": "integer",
                                                    "example": 5
                                                },
                                                "queued": {
                                                    "type": "integer",
                                                    "example": 12
                                                },
                                                "processing": {
                                                    "type": "integer",
                                                    "example": 3
                                                },
                                                "delivered": {
                                                    "type": "integer",
                                                    "example": 180
                                                },
                                                "failed": {
                                                    "type": "integer",
                                                    "example": 2
                                                },
                                                "retrying": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "permanently_failed": {
                                                    "type": "integer",
                                                    "example": 4
                                                },
                                                "cancelled": {
                                                    "type": "integer",
                                                    "example": 7
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/notifications": {
            "get": {
                "tags": [
                    "Notifications"
                ],
                "summary": "List notifications",
                "description": "List notifications with optional filters and cursor-based pagination.",
                "operationId": "911565ad9aff9ba7eded3f189509e578",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "pending",
                                "queued",
                                "processing",
                                "delivered",
                                "failed",
                                "retrying",
                                "permanently_failed",
                                "cancelled"
                            ]
                        }
                    },
                    {
                        "name": "channel",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "sms",
                                "email",
                                "push"
                            ]
                        }
                    },
                    {
                        "name": "date_from",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "date_to",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15,
                            "maximum": 100,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "cursor",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "nullable": true
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of notifications"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            },
            "post": {
                "tags": [
                    "Notifications"
                ],
                "summary": "Create a notification",
                "description": "Create a single notification. Returns 200 with existing notification if idempotency_key is duplicate.",
                "operationId": "91f8e779a9e46cb5cdda969e5a928a94",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "recipient",
                                    "channel"
                                ],
                                "properties": {
                                    "recipient": {
                                        "type": "string",
                                        "example": "+905551234567"
                                    },
                                    "channel": {
                                        "type": "string",
                                        "enum": [
                                            "sms",
                                            "email",
                                            "push"
                                        ]
                                    },
                                    "content": {
                                        "type": "string",
                                        "example": "Hello, world!",
                                        "nullable": true
                                    },
                                    "priority": {
                                        "type": "string",
                                        "enum": [
                                            "high",
                                            "normal",
                                            "low"
                                        ],
                                        "nullable": true
                                    },
                                    "idempotency_key": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "scheduled_at": {
                                        "type": "string",
                                        "format": "date-time",
                                        "nullable": true
                                    },
                                    "template_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "nullable": true
                                    },
                                    "template_variables": {
                                        "type": "object",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Notification created"
                    },
                    "200": {
                        "description": "Duplicate idempotency key — existing notification returned"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/notifications/{id}": {
            "get": {
                "tags": [
                    "Notifications"
                ],
                "summary": "Get notification by ID",
                "operationId": "f2edf725f41dd6c9a9338a6a7b39d779",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Notification details"
                    },
                    "404": {
                        "description": "Notification not found"
                    }
                }
            }
        },
        "/api/notifications/{id}/cancel": {
            "patch": {
                "tags": [
                    "Notifications"
                ],
                "summary": "Cancel a notification",
                "description": "Cancel a notification in pending, queued, or retrying status.",
                "operationId": "d732b31326d0804ebd5f6f67239070e9",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Notification cancelled"
                    },
                    "404": {
                        "description": "Notification not found"
                    },
                    "409": {
                        "description": "Notification cannot be cancelled"
                    }
                }
            }
        },
        "/api/notifications/{id}/trace": {
            "get": {
                "tags": [
                    "Notifications"
                ],
                "summary": "Get notification trace",
                "description": "Returns an ordered list of status transition log entries for a notification.",
                "operationId": "2b0c522455b5e5024fa9b81c6db617e3",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Trace log entries",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "event": {
                                                        "type": "string",
                                                        "example": "created"
                                                    },
                                                    "correlation_id": {
                                                        "type": "string",
                                                        "example": "abc-123"
                                                    },
                                                    "details": {
                                                        "type": "object",
                                                        "nullable": true
                                                    },
                                                    "created_at": {
                                                        "type": "string",
                                                        "format": "date-time"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Notification not found"
                    }
                }
            }
        },
        "/api/templates": {
            "get": {
                "tags": [
                    "Templates"
                ],
                "summary": "List templates",
                "description": "Returns all notification templates.",
                "operationId": "f1faaa62aa1ab331b2d37021c96c9751",
                "responses": {
                    "200": {
                        "description": "List of templates"
                    }
                }
            },
            "post": {
                "tags": [
                    "Templates"
                ],
                "summary": "Create a template",
                "description": "Create a new notification template.",
                "operationId": "822571666ffc158cdfaef5e1f9f93c03",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "channel",
                                    "body_template",
                                    "variables"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "welcome-sms"
                                    },
                                    "channel": {
                                        "type": "string",
                                        "enum": [
                                            "sms",
                                            "email",
                                            "push"
                                        ]
                                    },
                                    "body_template": {
                                        "type": "string",
                                        "example": "Hello {{name}}, welcome to {{company}}!"
                                    },
                                    "variables": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "name",
                                            "company"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Template created"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/templates/{template}": {
            "get": {
                "tags": [
                    "Templates"
                ],
                "summary": "Get template by ID",
                "operationId": "947424fc850182550e11bb89618667d9",
                "parameters": [
                    {
                        "name": "template",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Template details"
                    },
                    "404": {
                        "description": "Template not found"
                    }
                }
            },
            "put": {
                "tags": [
                    "Templates"
                ],
                "summary": "Update a template",
                "operationId": "073f45e312a7b942720edb46ea1d1d18",
                "parameters": [
                    {
                        "name": "template",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "channel",
                                    "body_template",
                                    "variables"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "welcome-sms-v2"
                                    },
                                    "channel": {
                                        "type": "string",
                                        "enum": [
                                            "sms",
                                            "email",
                                            "push"
                                        ]
                                    },
                                    "body_template": {
                                        "type": "string",
                                        "example": "Hi {{name}}, thanks for joining {{company}}!"
                                    },
                                    "variables": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "name",
                                            "company"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Template updated"
                    },
                    "404": {
                        "description": "Template not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Templates"
                ],
                "summary": "Delete a template",
                "operationId": "02a7c63ee388aa9907a2eacdbabbda09",
                "parameters": [
                    {
                        "name": "template",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Template deleted"
                    },
                    "404": {
                        "description": "Template not found"
                    },
                    "409": {
                        "description": "Template is referenced by existing notifications"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Notifications",
            "description": "Single notification operations"
        },
        {
            "name": "Batch",
            "description": "Batch operations"
        },
        {
            "name": "Templates",
            "description": "Notification template operations"
        },
        {
            "name": "Observability",
            "description": "Health check and metrics"
        }
    ]
}